{
  "name": "landing",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "deploy": "npm run build && wrangler deploy",
    "preview": "astro preview",
    "preview:cf": "npm run build && wrangler dev",
    "astro": "astro",
    "check": "astro check",
    "test:install": "docker compose -f tests/install/docker-compose.yml run --rm install-tests",
    "format": "prettier --write \"src/**/*.{astro,ts,css}\"",
    "format:check": "prettier --check \"src/**/*.{astro,ts,css}\""
  },
  "dependencies": {
    "@astrojs/starlight": "^0.38.4",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.1.9",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@fontsource-variable/figtree": "^5.2.10",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/outfit": "^5.2.8",
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.86.0"
  }
}
