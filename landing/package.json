{
  "name": "landing",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "deploy": "npm run build && wrangler deploy",
    "preview": "astro preview",
    "preview:cf": "npm run build && wrangler dev",
    "astro": "astro",
    "check": "astro check",
    "test:install": "docker compose -f tests/install/docker-compose.yml run --rm install-tests",
    "format": "prettier --write \"src/**/*.{astro,ts,css}\"",
    "format:check": "prettier --check \"src/**/*.{astro,ts,css}\""
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/starlight": "^0.39.3",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.4",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@fontsource-variable/figtree": "^5.2.10",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/outfit": "^5.2.8",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.98.0"
  },
  "overrides": {
    "yaml-language-server": {
      "yaml": "2.8.3"
    }
  }
}
