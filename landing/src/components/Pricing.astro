---
import { site } from '../config';

const paymentsEnabled = site.connect.paymentsEnabled;

const freeFeatures = [
  'Unlimited channels & recordings',
  'Full feature set, no gates',
  'Community support on Discord',
  'Source code on GitHub',
];

const connectFeatures = [
  'Public webhook URL. No port forwarding, no domain, no certs.',
  'Live notifications via EventSub (works behind CGNAT)',
];
---

<section id="pricing" data-reveal class="border-b border-border-soft py-48">
  <div class="mx-auto max-w-[1320px] px-8">
    <div class="mb-16 max-w-[760px]">
      <h2 class="text-display-2 text-balance">
        Free to run.<span class="text-fg-muted"> $5 if you don't want to fight your router.</span>
      </h2>
    </div>

    <div class="overflow-hidden rounded-xl border border-border grid grid-cols-1 lg:grid-cols-2">
      <!-- Self-host -->
      <div class="flex flex-col border-b border-border bg-surface p-9 lg:border-b-0 lg:border-r">
        <div class="mb-2 font-heading text-[17px] font-medium">Self-host</div>
        <div class="mb-1 font-heading text-[44px] font-normal leading-none tracking-[-0.02em]">
          Free<span class="ml-1.5 text-[16px] font-normal text-fg-muted">forever</span>
        </div>
        <div class="mb-6 text-[16.5px] text-fg">Your hardware. GPLv3.</div>
        <ul class="mb-6 flex flex-1 flex-col gap-2.5 list-none p-0 m-0">
          {
            freeFeatures.map((f) => (
              <li class="flex gap-2.5 text-[16.5px] text-fg">
                <span class="flex-none text-live">✓</span>
                {f}
              </li>
            ))
          }
        </ul>
        <a href="#install" class="btn btn-lg w-full">Read the install guide →</a>
      </div>

      <!-- Connect -->
      <div data-pricing-connect class="relative flex flex-col bg-deep-2 p-9">
        <span
          class="absolute right-4 top-4 rounded-full border border-primary/25 bg-primary/10 px-2 py-0.5 font-mono text-[12px] uppercase tracking-[0.06em] text-primary"
        >
          Relay
        </span>
        <div class="mb-3 font-heading text-[17px] font-medium">Connect</div>

        <!-- Plan toggle -->
        <div
          role="tablist"
          aria-label="Connect billing period"
          class="mb-4 inline-flex w-fit rounded-lg border border-border bg-surface p-1 font-mono text-[12px] uppercase tracking-[0.06em] text-fg-muted"
        >
          <button
            type="button"
            role="tab"
            data-plan-tab="monthly"
            aria-selected="true"
            class="rounded-md px-3 py-1.5 transition-colors aria-selected:bg-primary/15 aria-selected:text-primary"
          >
            Monthly
          </button>
          <button
            type="button"
            role="tab"
            data-plan-tab="yearly"
            aria-selected="false"
            class="flex items-center gap-1.5 rounded-md px-3 py-1.5 transition-colors aria-selected:bg-primary/15 aria-selected:text-primary"
          >
            Yearly
            <span class="rounded-sm bg-live/15 px-1 py-px font-mono text-[9.5px] tracking-[0.04em] text-live">
              save 17%
            </span>
          </button>
        </div>

        <div class="mb-1 font-heading text-[44px] font-normal leading-none tracking-[-0.02em]">
          <span data-plan-show="monthly">$5</span><span data-plan-show="yearly">$50</span><span
            class="ml-1.5 text-[16px] font-normal text-fg-muted"
          >
            <span data-plan-show="monthly">/ month</span>
            <span data-plan-show="yearly">/ year</span>
          </span>
        </div>
        <div class="mb-6 text-[16.5px] text-fg">
          <span data-plan-show="monthly">Self-host the recorder. We handle the annoying parts.</span>
          <span data-plan-show="yearly">$4.17 / month, billed once a year.</span>
        </div>

        <ul class="mb-6 flex flex-1 flex-col gap-2.5 list-none p-0 m-0">
          {
            connectFeatures.map((f) => (
              <li class="flex gap-2.5 text-[16.5px] text-fg">
                <span class="flex-none text-live">✓</span>
                {f}
              </li>
            ))
          }
        </ul>
        <p class="mb-4 text-[15.5px] italic leading-relaxed text-fg-muted">
          Webhook relay only. Videos stay on your hardware.
        </p>
        {
          paymentsEnabled ? (
            <a data-plan-cta href={site.connect.checkoutPath} class="btn btn-primary btn-lg w-full">
              Start 14-day trial →
            </a>
          ) : (
            <>
              <button type="button" class="btn btn-primary btn-lg w-full" disabled>
                Coming soon
              </button>
              <p class="mt-3 text-center text-[14.5px] leading-relaxed text-fg-muted">
                Payments are not open yet. Public launch is being prepared.
              </p>
            </>
          )
        }
      </div>
    </div>

    <p class="mt-8 font-mono text-[12px] tracking-[0.04em] text-fg-muted">
      Not affiliated with Twitch Interactive, Inc. "Twitch" is their trademark. See <a
        href="/legal/terms"
        class="underline decoration-fg-dim/40 underline-offset-2 hover:text-fg">Terms</a
      >,
      <a href="/legal/privacy" class="underline decoration-fg-dim/40 underline-offset-2 hover:text-fg"
        >Privacy</a
      >, and <a href="/legal/twitch" class="underline decoration-fg-dim/40 underline-offset-2 hover:text-fg"
        >Twitch trademark notice</a
      >.
    </p>
  </div>

  <style>
    /* The Connect tier swaps a few inline values when the plan toggle changes.
       Hide whichever variant doesn't match the active plan. JS sets
       data-active-plan on the card; CSS shows/hides the right spans. */
    [data-pricing-connect][data-active-plan='monthly'] [data-plan-show='yearly'],
    [data-pricing-connect][data-active-plan='yearly'] [data-plan-show='monthly'],
    [data-pricing-connect]:not([data-active-plan]) [data-plan-show='yearly'] {
      display: none;
    }
  </style>

  <script is:inline>
    (() => {
      const card = document.querySelector('[data-pricing-connect]');
      if (!card) return;

      const tabs = card.querySelectorAll('[data-plan-tab]');
      const cta = card.querySelector('[data-plan-cta]');
      const baseHref = cta?.getAttribute('href') ?? '/checkout';

      function selectPlan(plan) {
        card.dataset.activePlan = plan;
        tabs.forEach((t) => {
          t.setAttribute('aria-selected', t.dataset.planTab === plan ? 'true' : 'false');
        });
        if (cta) {
          const url = new URL(baseHref, window.location.origin);
          if (plan === 'yearly') url.searchParams.set('plan', 'yearly');
          else url.searchParams.delete('plan');
          cta.setAttribute('href', url.pathname + url.search);
          // Trial only applies to monthly. Yearly is a direct purchase, so the
          // CTA copy on yearly should not promise a trial.
          cta.textContent =
            plan === 'yearly' ? 'Get Connect yearly →' : 'Start 14-day trial →';
        }
      }

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => selectPlan(tab.dataset.planTab));
      });

      selectPlan('monthly');
    })();
  </script>
</section>
