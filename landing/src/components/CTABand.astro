---
import { site } from '../config';
---

<section data-reveal class="border-b border-border-soft py-48 text-center">
  <div class="mx-auto max-w-[1320px] px-8">
    <h2 class="mb-8 font-medium tracking-[-0.03em] leading-[0.9]" style="font-size: clamp(3rem, 9vw, 6rem);">
      <span class="block">Stop</span>
      <span class="block">losing</span>
      <span class="block">streams.</span>
    </h2>
    <p class="mx-auto mb-10 max-w-[560px] text-[18px] text-fg">
      One Docker command, one Twitch app credential. Archive starts filling tonight.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-3">
      <a href="#install" class="btn btn-primary btn-lg">Get started — it's free →</a>
      <a href={site.github} class="btn btn-lg" target="_blank" rel="noopener noreferrer">View on GitHub</a>
    </div>
  </div>
</section>
