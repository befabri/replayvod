---
import { site } from '../config';
---

<section data-reveal class="border-b border-border-soft py-32 text-center">
  <div class="mx-auto max-w-[1320px] px-8">
    <h2 class="mb-6 font-medium tracking-[-0.02em] leading-[1.05] text-balance" style="font-size: clamp(2.25rem, 5vw, 3.5rem);">
      One container. <span class="text-fg-muted">Your hardware. Your archive.</span>
    </h2>
    <p class="mx-auto mb-10 max-w-[560px] text-[17.5px] leading-[1.55] text-fg-muted">
      Pull the image, mount a volume, paste your Twitch app credentials. Recording starts the next time a followed channel goes live.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-3">
      <a href="#install" class="btn btn-primary btn-lg">Read the install →</a>
      <a href={site.github} class="btn btn-lg" target="_blank" rel="noopener noreferrer">View on GitHub</a>
    </div>
  </div>
</section>
