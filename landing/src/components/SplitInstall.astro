---
type Line =
  | { kind: 'comment'; text: string }
  | { kind: 'yaml'; indent: number; text: string }
  | { kind: 'blank' }
  | { kind: 'shell'; text: string }
  | { kind: 'status'; tag: string; value: string };

// What runs once you `docker compose up`. This is the real artifact, trimmed
// to the SQLite path so the panel stays scannable. The full compose with the
// Postgres profile is in the install docs.
const lines: Line[] = [
  { kind: 'comment', text: '# docker-compose.yml' },
  { kind: 'yaml', indent: 0, text: 'services:' },
  { kind: 'yaml', indent: 1, text: 'replayvod:' },
  { kind: 'yaml', indent: 2, text: 'image: ghcr.io/befabri/replayvod:latest' },
  { kind: 'yaml', indent: 2, text: 'restart: unless-stopped' },
  { kind: 'yaml', indent: 2, text: 'ports: ["8080:8080"]' },
  { kind: 'yaml', indent: 2, text: 'env_file: [./server/.env]' },
  { kind: 'yaml', indent: 2, text: 'volumes:' },
  { kind: 'yaml', indent: 3, text: '- ./data:/app/data       # videos + SQLite' },
  { kind: 'yaml', indent: 3, text: '- ./logs:/app/logs' },
  { kind: 'blank' },
  { kind: 'shell', text: '$ docker compose up -d' },
  { kind: 'status', tag: 'replayvod', value: 'listening on :8080' },
  { kind: 'status', tag: 'eventsub', value: 'subscribed · 8 channels' },
];
---

<section id="install" data-reveal class="border-b border-border-soft py-32">
  <div class="mx-auto grid max-w-[1320px] grid-cols-1 items-center gap-20 px-8 lg:grid-cols-2">
    <!-- Compose block (first on mobile, second on desktop via order). Restrained
         palette: dimmed comments, default fg for YAML, project primary for the
         shell line, mint only on the status output so it reads as runtime. -->
    <div
      role="img"
      aria-label="Sample docker-compose.yml for ReplayVOD with the SQLite profile."
      class="order-2 lg:order-1 overflow-hidden rounded-xl border border-[#2a2740] bg-[#1c1a2e] font-mono text-[14px] shadow-[0_18px_44px_rgba(0,0,0,0.35)]"
    >
      <!-- Flat title bar -->
      <div class="flex items-center border-b border-[#2a2740] px-5 py-3">
        <span class="text-[12px] uppercase tracking-[0.14em] text-[#8c8fa1]">~/replayvod · docker-compose.yml</span>
        <span class="ml-auto text-[11px] uppercase tracking-[0.2em] text-[#8c8fa1]/70">sqlite</span>
      </div>

      <!-- Body: line gutter + content rendered from one source so numbers always match -->
      <div class="grid grid-cols-[2.75rem_1fr] py-5 leading-[1.85]">
        <div class="select-none border-r border-[#2a2740] pr-3 text-right text-[12px] text-[#5b5b7a]/80 tabular-nums">
          {lines.map((_, i) => <div>{i + 1}</div>)}
        </div>

        <div class="overflow-x-auto pl-4 pr-5">
          {
            lines.map((line) => {
              if (line.kind === 'blank') return <div>&nbsp;</div>;
              if (line.kind === 'comment')
                return <div class="text-[#7a7c98]">{line.text}</div>;
              if (line.kind === 'yaml')
                return (
                  <div class="text-[#cdd6f4]">
                    <span>{' '.repeat(line.indent * 2)}</span>{line.text}
                  </div>
                );
              if (line.kind === 'shell')
                return (
                  <div class="text-primary">
                    {line.text}
                  </div>
                );
              return (
                <div class="grid grid-cols-[1.25rem_6rem_1fr] items-center text-[#a6da95]">
                  <span>●</span>
                  <span>{line.tag}</span>
                  <span class="text-[#a6da95]/70">{line.value}</span>
                </div>
              );
            })
          }
        </div>
      </div>
    </div>

    <!-- Text -->
    <div class="order-1 lg:order-2">
      <h3 class="mb-4 text-[34px] leading-[1.15] tracking-[-0.02em]">
        One <span class="text-primary">container</span>. Your hardware.
      </h3>
      <p class="mb-6 text-[17.5px] leading-[1.6] text-fg">
        One Docker Compose file, one Twitch dev app, one volume mount. Single binary with embedded SQLite.
        Zero phone-home.
      </p>
      <a href="/docs/install/" class="mb-6 inline-flex text-sm font-medium text-primary underline">
        Read full installation docs →
      </a>

      <ul class="m-0 list-none p-0">
        {
          [
            {
              label: 'Docker / Compose',
              detail: 'macOS, Linux, Windows, NAS, or homelab rack.',
            },
            {
              label: 'Reverse-proxy ready',
              detail: 'Caddy, Nginx, or Traefik. Bring your own TLS.',
            },
            {
              label: 'SQLite by default',
              detail: 'Switch to Postgres when you want it.',
            },
          ].map((item, i, arr) => (
            <li
              class:list={[
                'flex gap-3 items-start py-2.5',
                i < arr.length - 1 && 'border-b border-border-soft',
              ]}
            >
              <span class="mt-px flex-none text-live">✓</span>
              <div>
                <strong class="text-[17px] text-fg">{item.label}</strong>
                <small class="mt-0.5 block text-[15.5px] text-fg-muted">{item.detail}</small>
              </div>
            </li>
          ))
        }
      </ul>

    </div>
  </div>
</section>
