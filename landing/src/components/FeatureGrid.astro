---
type Feature = { tag: string; title: string; body: string };

const features: Feature[] = [
  {
    tag: 'schedule.add',
    title: 'Auto-record schedules',
    body: 'Add a channel. Pick rules: quality, category, tag filters, viewer floor.',
  },
  {
    tag: 'video.meta',
    title: 'Full metadata',
    body: 'Title, category, stream ID, viewer count, language, thumbnails. Indexed next to each recording.',
  },
  {
    tag: 'task.resume',
    title: 'Resumable captures',
    body: 'Network drops, host reboots, transient failures. Segments resume from the last good point.',
  },
  {
    tag: 'stream.copy',
    title: 'Source-quality output',
    body: '1080p60 at the original bitrate. No re-encode between Twitch and your disk.',
  },
  {
    tag: 'ui.live',
    title: 'Clean dashboard',
    body: 'Live status, running jobs, schedules, EventSub health, task logs, playback.',
  },
  {
    tag: 'storage.policy',
    title: 'Disk-aware storage',
    body: 'Local disk or S3-compatible. Per-schedule retention rules.',
  },
];
---

<section id="features" data-reveal class="border-b border-border-soft py-32">
  <div class="mx-auto max-w-[1320px] px-8">
    <div class="mb-16 max-w-[760px]">
      <h2 class="text-display-2 text-balance">
        Six things it does well.<span class="text-fg-muted"> Nothing more.</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 border-l border-t border-border-soft md:grid-cols-2">
      {
        features.map((f) => (
          <div class="grid grid-cols-1 gap-3 border-b border-r border-border-soft p-8 md:grid-cols-[140px_1fr] md:gap-8">
            <div class="font-mono text-[13px] text-primary">{f.tag}</div>
            <div>
              <h3 class="mb-2 text-[19px] font-medium">{f.title}</h3>
              <p class="m-0 text-[17px] leading-[1.6] text-fg-muted">{f.body}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
