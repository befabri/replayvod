---
type Feature = { title: string; body: string };

const features: Feature[] = [
  {
    title: 'Event-driven, not polling',
    body: 'Subscribes to Twitch EventSub. First segment hits disk within ~4s of stream.online. No 30-second poll loop missing the start.',
  },
  {
    title: 'Source-quality, no re-encode',
    body: '1080p60 at the original bitrate, written straight to MP4. CPU stays idle; ffmpeg only runs to remux.',
  },
  {
    title: 'Resumable',
    body: 'Network drops, host reboots, ISP blips. Segments resume from the last good point — no half-broken files.',
  },
  {
    title: 'Per-channel rules',
    body: 'Quality, category, tag filters, viewer floor, retention window. Configure once per channel and forget.',
  },
  {
    title: 'Indexed metadata',
    body: 'Title, category, stream ID, viewer count, language, thumbnails — stored next to each MP4 and queryable from the dashboard.',
  },
  {
    title: 'Local or S3',
    body: 'Mount any volume the kernel can see (NAS, ZFS pool, USB) or write to S3-compatible storage. Per-schedule retention rules clean up old recordings.',
  },
];
---

<section id="features" data-reveal class="border-b border-border-soft py-32">
  <div class="mx-auto max-w-[1320px] px-8">
    <div class="mb-16 max-w-[760px]">
      <h2 class="text-display-2 text-balance">
        What it does.<span class="text-fg-muted"> Honest list.</span>
      </h2>
      <p class="mt-5 max-w-[640px] text-[17.5px] leading-[1.55] text-fg-muted">
        Single Go binary, embedded SQLite by default, optional Postgres. Runs in one container next to whatever
        else is on your stack.
      </p>
    </div>

    <div class="grid grid-cols-1 border-l border-t border-border-soft md:grid-cols-2">
      {
        features.map((f) => (
          <div class="border-b border-r border-border-soft p-8">
            <h3 class="mb-2 text-[19px] font-medium">{f.title}</h3>
            <p class="m-0 text-[17px] leading-[1.6] text-fg-muted">{f.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
