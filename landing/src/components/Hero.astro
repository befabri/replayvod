---
import { site } from '../config';
---

<section class="relative overflow-hidden border-b border-border-soft pt-16 pb-14 lg:pt-40 lg:pb-36">
  <!-- Radial glow -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute left-1/2 top-[-200px] h-[400px] w-[800px] -translate-x-1/2
      bg-[radial-gradient(ellipse_at_center,rgba(131,144,250,0.10),transparent_70%)]"
  >
  </div>

  <div
    class="relative mx-auto grid max-w-[1320px] grid-cols-1 items-center gap-20 px-8 lg:grid-cols-[1.05fr_1fr] lg:gap-14"
  >
    <!-- Left: copy -->
    <div>
      <h1 class="mb-5 text-display-1 font-medium text-balance lg:max-w-[14em]">
        Record your <span class="text-primary">Twitch streams</span>. Keep them forever.
      </h1>

      <p class="mb-7 max-w-[480px] text-[19px] leading-[1.55] text-fg">
        Self-hosted VOD recorder. Twitch wipes VODs after 14 days — yours stays as long as your disk does.
      </p>

      <div class="mb-7 flex flex-wrap items-center gap-3">
        <a href="#install" class="btn btn-primary btn-lg">Get started — it's free →</a>
        <a href={site.github} class="btn btn-lg" target="_blank" rel="noopener noreferrer">View on GitHub</a>
      </div>

      <div class="flex gap-[22px] font-mono text-[13px] text-fg-muted">
        <span class="flex items-center gap-1.5"><span class="text-live">●</span> GPLv3 licensed</span>
        <span>self-hosted · zero telemetry</span>
      </div>

      <p class="mt-5 font-mono text-[12px] tracking-[0.04em] text-fg-muted">
        Not affiliated with Twitch Interactive, Inc. "Twitch" is their trademark.
      </p>
    </div>

    <!-- Right: mini dashboard visual. Flat Catppuccin-Macchiato palette matched to
         the install terminal and live-status panel. -->
    <div
      role="img"
      aria-label="Sample preview of the ReplayVOD dashboard showing live recordings, weekly count, used storage, and current throughput."
      class="rounded-xl border border-[#2a2740] bg-[#1c1a2e] p-[18px] shadow-[0_18px_44px_rgba(0,0,0,0.35)]"
    >
      <!-- Flat title bar -->
      <div
        class="mb-[14px] flex items-center justify-between border-b border-[#2a2740] pb-[14px] text-[12px] uppercase tracking-[0.14em] text-[#8c8fa1]"
      >
        <span>[ replayvod.local ]</span>
        <span class="flex items-center gap-1.5">
          <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
          <span>live</span>
        </span>
      </div>

      <!-- Stats strip -->
      <div
        class="mb-[14px] grid grid-cols-2 gap-y-3 border-b border-[#2a2740] py-3 sm:grid-cols-4 sm:gap-y-0"
      >
        {
          [
            { label: 'Recording', value: '4', unit: 'streams' },
            { label: 'This week', value: '142', unit: 'vods' },
            { label: 'Storage', value: '684', unit: 'GB' },
            { label: 'Throughput', value: '62.4', unit: 'MB/s' },
          ].map((stat, i) => (
            <div
              class:list={[
                'px-[14px] border-r border-[#2a2740]',
                i === 0 && 'pl-0',
                i === 1 && 'border-r-0 sm:border-r',
                i === 2 && 'pl-0 sm:pl-[14px]',
                i === 3 && 'pr-0 border-r-0',
              ]}
            >
              <div class="mb-1.5 font-mono text-[11.5px] uppercase tracking-[0.08em] text-fg-muted">
                {stat.label}
              </div>
              <div class="font-heading text-[25px] font-medium leading-none tracking-[-0.02em] tabular-nums">
                {stat.value}
                <span class="ml-1 font-sans text-[12px] text-fg-muted">{stat.unit}</span>
              </div>
            </div>
          ))
        }
      </div>

      <!-- Recording rows -->
      {
        [
          { init: 'P', name: 'pixelforge', meta: 'voxel engine, day 47 · 1080p60', pct: 42, live: true },
          { init: 'N', name: 'neon_arena', meta: 'ranked diamond · 22.1 MB/s', pct: 68, live: true },
          { init: 'C', name: 'cartographer', meta: 'remux stage · 1080p30', pct: 84, live: true },
          { init: 'A', name: 'asterfox', meta: 'queued · schedule match', pct: 3, live: false },
        ].map((row) => (
          <div class="grid grid-cols-[24px_1fr_auto_auto] items-center gap-2.5 border-b border-[#2a2740] py-[9px] text-[14px] last:border-b-0">
            <div
              class="grid h-[22px] w-[22px] place-items-center rounded-full bg-[#2a2740] font-heading text-[12px] font-semibold text-fg-muted"
            >
              {row.init}
            </div>
            <div>
              <div class="font-medium">{row.name}</div>
              <div class="font-mono text-[12px] text-fg-muted">{row.meta}</div>
            </div>
            <div class="relative h-[3px] w-[70px] overflow-hidden rounded-sm bg-[#15131f]">
              <span class="absolute inset-y-0 left-0 rounded-sm bg-primary" style={`width: ${row.pct}%`} />
            </div>
            <div class="min-w-[28px] text-right font-mono text-[12px] text-fg-muted">{row.pct}%</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
