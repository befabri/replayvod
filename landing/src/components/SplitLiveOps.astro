---
type Segment = { l: string; w: string; live?: boolean; danger?: boolean };
type ChannelStatus = 'live' | 'idle' | 'error';
type Channel = { name: string; status: ChannelStatus; segments: Segment[] };

const channels: Channel[] = [
  {
    name: 'pixelforge',
    status: 'live',
    segments: [
      { l: '6%', w: '18%' },
      { l: '36%', w: '22%' },
      { l: '76%', w: '24%', live: true },
    ],
  },
  {
    name: 'neon_arena',
    status: 'live',
    segments: [
      { l: '12%', w: '30%' },
      { l: '70%', w: '30%', live: true },
    ],
  },
  {
    name: 'quietstream',
    status: 'idle',
    segments: [
      { l: '22%', w: '14%' },
      { l: '50%', w: '18%' },
    ],
  },
  {
    name: 'cartographer',
    status: 'live',
    segments: [
      { l: '4%', w: '12%' },
      { l: '84%', w: '16%', live: true },
    ],
  },
  { name: 'asterfox', status: 'idle', segments: [{ l: '30%', w: '20%' }] },
  { name: 'mechworks', status: 'error', segments: [{ l: '14%', w: '6%', danger: true }] },
  { name: 'cinderhex', status: 'idle', segments: [{ l: '56%', w: '8%' }] },
];

const liveCount = channels.filter((c) => c.status === 'live').length;
---

<section data-reveal class="border-b border-border-soft py-32">
  <div class="mx-auto grid max-w-[1320px] grid-cols-1 items-center gap-20 px-8 lg:grid-cols-2">
    <!-- Text -->
    <div>
      <h3 class="mb-4 text-[34px] leading-[1.15] tracking-[-0.02em]">
        Watch what's happening, not just what happened.
      </h3>
      <p class="mb-6 text-[17.5px] leading-[1.6] text-fg">
        Built for operators, not screenshots. Live state stays in sync through EventSub and SSE.
      </p>
      <ul class="m-0 list-none p-0">
        {
          [
            {
              label: 'Live channel status',
              detail: 'Followed channels stay in sync through the stream.status SSE feed.',
            },
            {
              label: 'Running job progress',
              detail: 'Active downloads show stage, bytes written, speed, ETA, and completion percent.',
            },
            {
              label: 'Event log stream',
              detail: 'Tagged events for recorder, EventSub, scheduler, remuxer, and storage.',
            },
          ].map((item, i, arr) => (
            <li
              class:list={[
                'flex gap-3 items-start py-2.5',
                i < arr.length - 1 && 'border-b border-border-soft',
              ]}
            >
              <span class="mt-px flex-none text-live">✓</span>
              <div>
                <strong class="text-[17px] text-fg">{item.label}</strong>
                <small class="mt-0.5 block text-[15.5px] text-fg-muted">{item.detail}</small>
              </div>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Radar visual -->
    <div
      role="img"
      aria-label="Sample live status panel showing followed channel state for seven channels."
      class="rounded-xl border border-border bg-surface p-5 font-mono text-[14px] shadow-[0_24px_56px_rgba(0,0,0,0.35)]"
    >
      <!-- Header -->
      <div
        class="mb-3 flex items-center justify-between border-b border-border-soft pb-3 text-[13px] uppercase tracking-[0.06em] text-fg-muted"
      >
        <span>live status · followed channels</span>
        <span class="flex items-center gap-1.5 normal-case tracking-normal">
          <span class="h-1.5 w-1.5 rounded-full bg-live"></span>
          <span class="text-live">{liveCount} recording</span>
        </span>
      </div>

      <!-- Hour scale -->
      <div class="mb-2 grid grid-cols-[88px_1fr] gap-3.5">
        <div></div>
        <div class="relative h-3 text-[11.5px] tracking-[0.04em] text-fg-muted">
          <span class="absolute left-0">−24h</span>
          <span class="absolute left-1/4 -translate-x-1/2">−18h</span>
          <span class="absolute left-1/2 -translate-x-1/2">−12h</span>
          <span class="absolute left-3/4 -translate-x-1/2">−6h</span>
          <span class="absolute right-0 text-primary">NOW</span>
        </div>
      </div>

      <!-- Rows -->
      {
        channels.map((ch) => (
          <div class="mb-1.5 grid h-[22px] grid-cols-[88px_1fr] items-center gap-3.5">
            <div class="flex items-center gap-2 text-[13px] text-fg-muted">
              <span
                class:list={[
                  'h-1.5 w-1.5 flex-none rounded-full',
                  ch.status === 'live' && 'bg-live',
                  ch.status === 'idle' && 'bg-fg-dim/60',
                  ch.status === 'error' && 'bg-danger',
                ]}
              />
              <span class="truncate">{ch.name}</span>
            </div>
            <div class="relative h-2 overflow-hidden rounded-sm bg-deep">
              <span class="absolute top-0 bottom-0 left-1/4 w-px bg-border-soft" />
              <span class="absolute top-0 bottom-0 left-1/2 w-px bg-border-soft" />
              <span class="absolute top-0 bottom-0 left-3/4 w-px bg-border-soft" />
              {ch.segments.map((seg) => (
                <span
                  class:list={[
                    'absolute top-0 bottom-0 rounded-sm',
                    seg.danger ? 'bg-danger opacity-80' : seg.live ? 'bg-live' : 'bg-fg-dim opacity-40',
                  ]}
                  style={`left: ${seg.l}; width: ${seg.w}`}
                />
              ))}
              <span class="absolute inset-y-[-3px] right-0 w-px bg-primary shadow-[0_0_6px_var(--color-primary)]" />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
