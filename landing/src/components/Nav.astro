---
import { site } from '../config';

interface Props {
  minimal?: boolean;
}

const { minimal = false } = Astro.props;
const accountEnabled = site.connect.accountEnabled;
---

<nav class="sticky top-0 z-50 border-b border-border-soft bg-bg/[0.86] backdrop-blur-[14px]">
  <div class="mx-auto flex h-16 max-w-[1320px] items-center justify-between px-8">
    <a href="/" class="font-heading text-[19px] tracking-[-0.04em]">
      <span class="font-semibold">Replay</span><span class="font-bold text-primary">VOD</span><span
        class="text-primary">.</span>
    </a>

    {
      !minimal && (
        <>
          <div class="hidden gap-7 text-sm text-fg-muted lg:flex">
            <a href="/#features" class="transition-colors duration-150 hover:text-fg">
              Features
            </a>
            <a href="/#how" class="transition-colors duration-150 hover:text-fg">
              How it works
            </a>
            <a href="/#pricing" class="transition-colors duration-150 hover:text-fg">
              Pricing
            </a>
            <a href="/docs/" class="transition-colors duration-150 hover:text-fg">
              Docs
            </a>
          </div>

          <div class="flex items-center gap-2">
            <a
              href={site.github}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="View ReplayVOD on GitHub"
              title="View on GitHub"
              class="grid h-10 w-10 place-items-center rounded-lg text-fg-muted transition-colors duration-150 hover:bg-surface hover:text-fg"
            >
              <svg
                aria-hidden="true"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.7-3.87-1.37-3.87-1.37-.52-1.33-1.28-1.69-1.28-1.69-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.74.4-1.25.73-1.54-2.55-.29-5.23-1.27-5.23-5.66 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.16 1.17.92-.26 1.9-.39 2.88-.39s1.96.13 2.88.39c2.2-1.48 3.16-1.17 3.16-1.17.62 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.07 0 4.4-2.69 5.36-5.25 5.65.41.36.78 1.05.78 2.12v3.14c0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"
                ></path>
              </svg>
            </a>
            {accountEnabled && (
              <a href="/login" class="btn btn-ghost">
                Sign in
              </a>
            )}
            <a href="/docs/install/" class="btn btn-primary">
              Install →
            </a>
          </div>
        </>
      )
    }

    {
      minimal && (
        <a href="/" class="text-sm text-fg-muted transition-colors duration-150 hover:text-fg">
          ← Back to site
        </a>
      )
    }
  </div>
</nav>
