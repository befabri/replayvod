{
  "name": "relay",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8788 --inspector-port 9230",
    "deploy": "wrangler deploy --minify",
    "pretest": "wrangler types --env-interface CloudflareBindings",
    "test": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit && node --import tsx --test --test-concurrency=1 tests/*.test.ts",
    "verify:prod": "tsx scripts/verify-prod.ts",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "hono": "^4.12.23"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.98.0"
  }
}
