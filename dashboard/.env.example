# Backend origin. Leave empty for same-origin (Vite dev proxy forwards
# /api/* to the Go server). Set to a full origin (no trailing slash) for
# cross-origin deployments. The API path (/api/v1/...) is appended at
# each call site, so this value should NOT include /api/v1.
VITE_API_URL=
# Example for cross-origin:
# VITE_API_URL=http://localhost:8080
