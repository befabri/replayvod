# Database
DATABASE_DRIVER=postgres           # "postgres" or "sqlite"
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DATABASE=replayvod
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_SSL_MODE=disable
SQLITE_PATH=./data/replayvod.db

# Twitch
TWITCH_CLIENT_ID=
TWITCH_SECRET=
HMAC_SECRET=

# Optional: refresh token for an authenticated playback account. Unlocks
# ad-free recording on Turbo accounts and HEVC on channels whose
# transcode ladder serves HEVC only to authenticated viewers. Leave
# empty to use anonymous playback (works for public non-sub-only
# streams).
TWITCH_SERVICE_ACCOUNT_REFRESH_TOKEN=

# Server
HOST=0.0.0.0
PORT=8080

# Security
SESSION_SECRET=                    # 32+ byte key for session encryption
WHITELIST_ENABLED=false
WHITELISTED_USER_IDS=              # Comma-separated Twitch user IDs
OWNER_TWITCH_ID=                   # First owner (auto-assigned owner role)

# URLs
CALLBACK_URL=http://localhost:8080/api/v1/auth/twitch/callback
WEBHOOK_CALLBACK_URL=http://localhost:8080/api/v1/webhook/callback
FRONTEND_URL=http://localhost:3000

# Optional Connect relay. WEBHOOK_CALLBACK_URL must be the public HTTPS relay
# ingest URL when this is enabled. RELAY_SUBSCRIBE_URL must use wss:// and the
# same relay host/token. RELAY_LOCAL_CALLBACK_URL is where the local relay agent
# replays signed EventSub frames. Leave it empty for
# http://127.0.0.1:${PORT}/api/v1/webhook/callback. If set, it must stay on
# loopback and use /api/v1/webhook/callback.
RELAY_SUBSCRIBE_URL=
RELAY_LOCAL_CALLBACK_URL=

# Docker compose only. The bundled deploy serves the built dashboard from
# the Go server on the same origin, so compose derives FRONTEND_URL,
# CALLBACK_URL, and WEBHOOK_CALLBACK_URL from this base URL.
PUBLIC_BASE_URL=http://localhost:8080

# Docker compose only. Overrides the public EventSub callback without changing
# the OAuth/frontend URLs. Set this to the relay ingest URL when using Connect,
# e.g. https://relay.replayvod.com/u/<token>.
PUBLIC_WEBHOOK_CALLBACK_URL=

# Docker compose only. Picks the database profile — "sqlite" for a
# single-container deploy, "postgres" for a two-container setup. Without
# this (or an explicit `--profile` flag), `docker compose up` starts
# nothing.
COMPOSE_PROFILES=sqlite

# Paths
VIDEO_DIR=./data/videos
THUMBNAIL_DIR=./data/thumbnails
DASHBOARD_DIR=                     # Path to built dashboard (production)
SCRATCH_DIR=./data/.scratch        # Keep on same filesystem as VIDEO_DIR (os.Rename)
