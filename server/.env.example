# Database
# "postgres" or "sqlite"
DATABASE_DRIVER=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DATABASE=replayvod
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_SSL_MODE=disable
SQLITE_PATH=./data/replayvod.db

# Twitch
TWITCH_CLIENT_ID=
TWITCH_SECRET=

# Optional. EventSub HMAC secret, shared with Twitch for webhook verification.
# Auto-generated and stored in the database on first run if unset; set it only
# to seed a specific value (e.g. an existing secret) on the first run.
# HMAC_SECRET=

# Optional: refresh token for an authenticated playback account. Unlocks
# ad-free recording on Turbo accounts and HEVC on channels whose
# transcode ladder serves HEVC only to authenticated viewers. Leave
# empty to use anonymous playback (works for public non-sub-only
# streams).
TWITCH_SERVICE_ACCOUNT_REFRESH_TOKEN=

# Server
HOST=0.0.0.0
PORT=8080

# Security
# Required: 32+ character key for session encryption. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=
WHITELIST_ENABLED=false
# Comma-separated Twitch user IDs
WHITELISTED_USER_IDS=
# Optional numeric Twitch user ID to preassign as owner. Leave empty and the
# first successful login becomes owner.
OWNER_TWITCH_ID=

# Public URL. Normal Docker deployments only set this; OAuth and dashboard
# redirects are derived from it. Leave empty for local dev with the Vite
# dashboard on http://localhost:3000. Compose and the installer default Docker
# installs to http://localhost:8080 when this is empty.
PUBLIC_BASE_URL=
# Optional comma-separated extra browser origins for split dashboard/API setups.
TRUSTED_ORIGINS=

WEBHOOK_CALLBACK_URL=

# Server mode: leave empty to configure live/title behavior from the owner dashboard.
# A complete env config skips onboarding and always wins over app settings.
# Valid env values: "off", "poll", "direct", or "relay".
# "poll" uses Helix polling for live detection and title changes; no callback URL.
# "direct" requires WEBHOOK_CALLBACK_URL to be public HTTPS.
# "relay" requires RELAY_INGEST_URL=https://... and RELAY_SUBSCRIBE_URL=wss://...
SERVER_MODE=

# Optional Connect relay. RELAY_INGEST_URL is the public HTTPS relay URL Twitch
# posts to. RELAY_SUBSCRIBE_URL is the outbound WebSocket URL this recorder
# dials. Both must use the same relay host/token. RELAY_LOCAL_CALLBACK_URL is
# where the local relay agent replays signed EventSub frames. Leave it empty for
# http://127.0.0.1:${PORT}/api/v1/webhook/callback. If set, it must stay on
# loopback and use /api/v1/webhook/callback.
RELAY_INGEST_URL=
RELAY_SUBSCRIBE_URL=
RELAY_LOCAL_CALLBACK_URL=

# Docker compose only. Picks the database profile — "sqlite" for a
# single-container deploy, "postgres" for a two-container setup. Without
# this (or an explicit `--profile` flag), `docker compose up` starts
# nothing.
COMPOSE_PROFILES=sqlite

# Paths
VIDEO_DIR=./data/videos
THUMBNAIL_DIR=./data/thumbnails
# Optional built dashboard override (manual/source packaging)
DASHBOARD_DIR=
# Keep on same filesystem as VIDEO_DIR (os.Rename)
SCRATCH_DIR=./data/.scratch
