# Database
DATABASE_DRIVER=postgres           # "postgres" or "sqlite"
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DATABASE=replayvod
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_SSL_MODE=disable
SQLITE_PATH=./data/replayvod.db

# Twitch
TWITCH_CLIENT_ID=
TWITCH_SECRET=
HMAC_SECRET=

# Optional: refresh token for an authenticated playback account. Unlocks
# ad-free recording on Turbo accounts and HEVC on channels whose
# transcode ladder serves HEVC only to authenticated viewers. Leave
# empty to use anonymous playback (works for public non-sub-only
# streams).
TWITCH_SERVICE_ACCOUNT_REFRESH_TOKEN=

# Server
HOST=0.0.0.0
PORT=8080

# Security
SESSION_SECRET=                    # 32+ byte key for session encryption
WHITELIST_ENABLED=false
WHITELISTED_USER_IDS=              # Comma-separated Twitch user IDs
OWNER_TWITCH_ID=                   # First owner (auto-assigned owner role)

# URLs
CALLBACK_URL=http://localhost:8080/api/v1/auth/twitch/callback
WEBHOOK_CALLBACK_URL=http://localhost:8080/api/v1/webhook/callback
FRONTEND_URL=http://localhost:3000

# Paths
VIDEO_DIR=./data/videos
THUMBNAIL_DIR=./data/thumbnails
YTDLP_PATH=yt-dlp
DASHBOARD_DIR=                     # Path to built dashboard (production)
SCRATCH_DIR=./data/.scratch        # Keep on same filesystem as VIDEO_DIR (os.Rename)
